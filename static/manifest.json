{
  "$schema": "https://json.schemastore.org/chrome-manifest",
  "name": "TrustThing",
  "description": "Verifies open-source webapps against their published source.",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:8080/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "activeTab",
    "declarativeNetRequest",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8080/*"
  ]
}
