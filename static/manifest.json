{
  "$schema": "https://json.schemastore.org/chrome-manifest",
  "name": "TrustThing",
  "description": "Verifies open-source webapps against their published source.",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "declarativeNetRequest",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
